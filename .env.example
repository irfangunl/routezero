# Dev mode: auto-generates encryption key if ENCRYPTION_KEY is not set
DEV_MODE=true

# Encryption key for API key storage (64 hex chars). Leave empty in dev mode
# to auto-generate. Required in production.
ENCRYPTION_KEY=

# Server port (default: 3001)
PORT=3001

# Comma-separated extra origins allowed to call the API from a browser.
# localhost:5173, 127.0.0.1:5173, [::1]:5173 are allowed by default for the
# Vite dev dashboard. Only set this if you serve the dashboard from a
# different host than the API (e.g. http://my-server.local).
# DASHBOARD_ORIGINS=http://my-server.local,http://192.168.1.50

# Log retention in days (default: 30). Old request logs are pruned every 6 hours.
# LOG_RETENTION_DAYS=30

# Webhook URL for key expiry and 429 rate spike notifications.
# Fires POST requests with JSON payload. Leave empty to disable.
# WEBHOOK_URL=https://hooks.example.com/routezero
